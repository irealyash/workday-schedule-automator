{
    "manifest_version": 3,
    "name": "UBC Scheduler",
    "version": "1.0.0",
    "description": "Automates course scheduling and timetable generation for UBC students via Workday.",
   "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
],
    "host_permissions": [
        "https://*.myworkday.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "js/background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.myworkday.com/*"
            ],
            "js": [
                "js/navigation.js"
            ]
        }
    ]
}